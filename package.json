{
	"name": "html-canvas",
	"version": "0.1.1",
	"description": "Open local HTML study pages with native browser rendering for CSS, MathML, SVG diagrams, and visual notes.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"html",
		"htm",
		"obsidian",
		"obsidian-plugin"
	],
	"author": "x1han",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"esbuild": "^0.25.11",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	},
	"dependencies": {
		"@zip.js/zip.js": "^2.6.52",
		"mark.js": "^8.11.1",
		"mhtml-to-html": "^2.0.1",
		"number-precision": "^1.6.0",
		"single-filez-core": "^1.0.26"
	}
}
